{
  "dashboard": {
    "title": "Machine Edge Layer - Sensor Overview",
    "tags": ["mel", "edge", "platform"],
    "timezone": "browser",
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Machine Temperature (°C)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "machine_temperature_celsius",
            "legendFormat": "Temperature",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 75 },
                { "color": "red", "value": 90 }
              ]
            },
            "custom": {
              "thresholdsStyle": { "mode": "area" }
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Vibration Level (mm/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "machine_vibration_mm_s",
            "legendFormat": "Vibration",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "mm/s",
            "color": { "mode": "palette-classic" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 4 },
                { "color": "red", "value": 6 }
              ]
            },
            "custom": {
              "thresholdsStyle": { "mode": "area" }
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Machine Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "machine_status",
            "legendFormat": "Status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "ERROR", "color": "red" } } },
              { "type": "value", "options": { "1": { "text": "WARNING", "color": "yellow" } } },
              { "type": "value", "options": { "2": { "text": "RUNNING", "color": "green" } } }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "green", "value": 2 }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "textMode": "value"
        }
      },
      {
        "id": 4,
        "title": "Current Temperature",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "machine_temperature_celsius",
            "legendFormat": "Temp",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "min": 0,
            "max": 120,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 75 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Total Sensor Readings",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sensor_readings_total",
            "legendFormat": "Readings",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "blue", "value": null }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 6,
        "title": "HTTP Requests/sec",
        "type": "timeseries",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "rate(edge_http_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 7,
        "title": "Sensor Processing Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(sensor_processing_seconds_bucket[5m]))",
            "legendFormat": "p95 latency",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "Readings per Minute",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "rate(sensor_readings_total[1m]) * 60",
            "legendFormat": "readings/min",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}